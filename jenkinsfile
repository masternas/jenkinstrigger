pipeline {
    agent any
    tools {
        maven 'MAVEN3.9'
        jdk 'JDK17'
    }

    environment {
        SONAR_HOST_URL = 'http://192.168.56.13'
        SONAR_TOKEN = credentials('sonar_token')
    // SONAR_TOKEN should be defined in Jenkins credentials for security
    }

    stages {
        stage('Fetch code') {
            steps {
                git branch: 'atom', url: 'https://github.com/hkhcoder/vprofile-project.git'
            }
        }

        stage('Build') {
            steps {
                sh 'mvn install'
            }
        }

        stage('Unit test') {
            steps {
                sh 'mvn test'
            }
        }

        stage('mvn checkstyle') {
            steps {
                sh 'mvn checkstyle:checkstyle'
            }
        }

        stage('SonarQube Analysis') {
            steps {
                withSonarQubeEnv('sonarqube server') {
                    sh """
                         mvn sonar:sonar \
                            -Dsonar.projectKey=vprofile-project_pipeline_as_code \
                            -Dsonar.projectName=VProfile_pipeline_as_code \
                            -Dsonar.projectVersion=1.0 \
                            -Dsonar.host.url=${SONAR_HOST_URL} \
                            -Dsonar.login=${SONAR_TOKEN}
                    """
                }
            }
        }
        stage('Upload to Nexus') {
            steps {
                nexusArtifactUploader(
            nexusVersion: 'nexus3',
            protocol: 'http',
            nexusUrl: '192.168.56.12:8081',   // replace with your Nexus server host/port
            groupId: 'com.qa.vprofile',      // your Maven groupId
            version: "${env.BUILD_ID}-${env.BUILD_TIMESTAMP}", // version can be dynamic based on build info
            repository: 'vprofile-repo',     // Nexus repository name
            credentialsId: 'nexus_login', // Jenkins credentials ID for Nexus user/pass
            artifacts: [
                [
                    artifactId: 'vprofile',
                    classifier: '',
                    file: 'target/vprofile-v2.war',
                    type: 'war'
                ]
            ]
            )
            }
        }
    }
    post {
        success {
            slackSend(
                channel: '#devops_ci',
                color: 'good',
                message: "✅ Pipeline succeeded: ${env.JOB_NAME} #${env.BUILD_NUMBER}",
                teamDomain: 'ictpathway',
                tokenCredentialId: 'slack_token'
            )
            echo "Build and SonarQube analysis completed successfully."
        }
        failure {
            slackSend(
                channel: '#devops_ci',
                color: 'danger',
                message: "❌ Pipeline failed: ${env.JOB_NAME} #${env.BUILD_NUMBER}",
                teamDomain: 'ictpathway',
                tokenCredentialId: 'slack_token'
            )
            echo "Build or SonarQube analysis failed."
        }
        always {
            slackSend(
                 channel: '#devops_ci',
                color: '#439FE0',
                message: "ℹ️ Pipeline finished: ${env.JOB_NAME} #${env.BUILD_NUMBER}",
                teamDomain: 'ictpathway',
                tokenCredentialId: 'slack_token'
            )
            echo "Pipeline execution completed."
        }
    }
}

	
